# Connection string for a READ-ONLY Postgres role. The MCP server enforces
# SELECT-only at the SQL layer too (see src/sqlGuard.ts), but the DB role is
# defense in depth — neither layer alone is sufficient.
DATABASE_URL=postgresql://mcp_reader:mcp_reader@localhost:5433/bench

# Optional. Hard cap on rows returned per query. Default 1000.
MAX_ROWS=1000

# Optional. Per-query timeout in ms. Default 5000.
STATEMENT_TIMEOUT_MS=5000
